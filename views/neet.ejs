<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= seo ? seo.title : 'Agrim Classes' %></title>
<meta name="description" content="<%= seo ? seo.desc : 'Best Coaching Institute in Deoli' %>">
<meta name="keywords" content="<%= seo ? seo.keywords : 'education, coaching' %>">
    <link rel="stylesheet" href="style.css?v=1.1">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
</head>

<body>

    <script src="header.js"></script>
    <my-header></my-header>

    <section class="breadcrumb-area">

        <div class="shape-globe">
            <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="#FFA500" stroke-width="1.5"
                stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M2 12h20"></path>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z">
                </path>
            </svg>
        </div>

        <div class="shape-loop">
            <svg width="40" height="40" viewBox="0 0 100 100" fill="none" stroke="#C4C6E5" stroke-width="12"
                stroke-linecap="round">
                <path d="M30,20 Q60,5 80,40 T50,90 T20,60" />
            </svg>
        </div>

        <div class="shape-scribbles">
            <svg width="80" height="100" viewBox="0 0 100 100" fill="none" stroke="#FFC07F" stroke-width="3">
                <path d="M80,10 Q90,20 85,30 T90,50" />
                <path d="M60,15 Q70,5 75,25 T80,40" />
                <path d="M90,5 Q100,15 95,25 T100,45" />
            </svg>
        </div>

        <div class="container">
            <div class="banner-content align-left">
                <span class="sub-heading">Agrim Classes</span>
                <h1 class="page-title">NEET & Other Medical Exam</h1>
                <ul class="breadcrumb-list">
                    <li><a href="index.html">Home</a></li>
                    <li class="separator"><i class="fas fa-chevron-right"></i></li>
                    <li>Courses</li>
                    <li class="separator"><i class="fas fa-chevron-right"></i></li>
                    <li class="active">NEET</li>
                </ul>
            </div>
        </div>
    </section>

<section class="course-intro-creative">
    <div class="container">
        <div class="intro-grid">
            <div class="intro-main">
                <span class="section-tag">Realize Your Dreams</span>
                <h2 class="creative-heading">Dedicated to Aspiring <span class="highlight">Medical Professionals</span></h2>
                <p class="creative-desc">
                    At Agrim Classes, we are dedicated to helping aspiring medical professionals realize their dreams. We provide expert guidance to students preparing for various medical entrance exams, including NEET and AIIMS. Our institute stands out for its commitment to fostering excellence and offering unwavering support throughout your journey to medical school.
                </p>
                
                <div class="highlight-box">
                    <h4><i class="fas fa-user-md"></i> Personalized Mentorship</h4>
                    <p>
                        We offer personalized mentorship from experienced educators who help students navigate the complexities of medical entrance exams with confidence. Our comprehensive curriculum covers all essential topics, ensuring students are fully equipped for success.
                    </p>
                </div>
            </div>

            <div class="intro-features">
                <div class="feature-card-small">
                    <div class="icon-circle"><i class="fas fa-microscope"></i></div>
                    <h5>Foundation Course</h5>
                    <p>Aimed at students transitioning from Class 10 to 11, laying a strong academic groundwork for medical entrance exams.</p>
                </div>
                <div class="feature-card-small">
                    <div class="icon-circle"><i class="fas fa-heartbeat"></i></div>
                    <h5>Intensive Regular Course</h5>
                    <p>Designed for students in Classes 11 and 12 to ensure they are thoroughly prepared for their target medical entrance exam.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="boosters-section">
    <div class="" style="margin-left: 70px; margin-right: 70px; padding-top: 60px;">
        <div class="text-center mb-5">
            <h2 class="main-heading">Exam Preparation Boosters</h2>
        </div>

        <div class="boosters-grid">
            <div class="booster-card card-red">
                <div class="icon-wrapper"><i class="fas fa-user-friends"></i></div>
                <h4>India's Best<br>Ever Team</h4>
            </div>

            <div class="booster-card card-green">
                <div class="icon-wrapper"><i class="fas fa-database"></i></div>
                <h4>Small Batch Size<br>(Special 20)</h4>
            </div>

            <div class="booster-card card-dark-blue">
                <div class="icon-wrapper"><i class="fas fa-book-open"></i></div>
                <h4>Doubt Clearing<br>Session</h4>
            </div>

            <div class="booster-card card-light-blue">
                <div class="icon-wrapper"><i class="far fa-building"></i></div>
                <h4>Complete Study Package<br>(Online | Offline)</h4>
            </div>

            <div class="booster-card card-grey">
                <div class="icon-wrapper"><i class="fas fa-download"></i></div>
                <h4>Fortnight<br>Test</h4>
            </div>
        </div>
    </div>
</section>

<section class="eligibility-section">
    <div class="" style="margin-left: 70px; margin-right: 70px; justify-content: center;">
        <h3 class="table-title">NEET UG 2025 Details</h3>
        
        <div class="table-wrapper">
            <table class="eligibility-table">
                <thead>
                    <tr>
                        <th class="th-criteria">NEET UG 2026</th>
                        <th class="th-details">Details</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="criteria-name">Exam Name</td>
                        <td>National Eligibility Cum Entrance Test (NEET) 2026</td>
                    </tr>
                    <tr>
                        <td class="criteria-name">Exam Level</td>
                        <td>Undergraduate Examination</td>
                    </tr>
                    <tr>
                        <td class="criteria-name">Conducting Body</td>
                        <td>National Testing Agency (NTA)</td>
                    </tr>
                    <tr>
                        <td class="criteria-name">Courses Offered</td>
                        <td>MBBS, BDS, BSc Nursing, BAMS, BVSC & AH</td>
                    </tr>
                    <tr>
                        <td class="criteria-name">Exam Mode</td>
                        <td>Offline or Paper Pencil Based Test (PBT)</td>
                    </tr>
                    <tr>
                        <td class="criteria-name">Exam Frequency</td>
                        <td>Once a year</td>
                    </tr>
                    <tr>
                        <td class="criteria-name">Exam Duration</td>
                        <td>3 hours and 20 minutes</td>
                    </tr>
                    <tr>
                        <td class="criteria-name">Exam Fees</td>
                        <td>INR 1,700 (General), 1,600 (OBC), 1,000 (Reserved category candidates), 9,500 (Foreign nationals)</td>
                    </tr>
                    <tr>
                        <td class="criteria-name">Marking Scheme</td>
                        <td>4 marks for each correct answer; -1 mark for each incorrect answer</td>
                    </tr>
                    <tr>
                        <td class="criteria-name">Official Helpline</td>
                        <td>011-69227700, 011-40759000<br>Email: neet@nta.ac.in, neet1@nta.ac.in</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="course-cta text-center">
            <h3>Ready to start your journey to medical school?</h3>
            <a href="contact.html" class="btn-primary">Join Agrim Classes Today <i class="fas fa-arrow-right"></i></a>
        </div>
    </div>
</section>

<my-footer></my-footer>


<script src="footer.js"></script>
    </body>