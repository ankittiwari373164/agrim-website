<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= seo ? seo.title : 'Agrim Classes' %></title>
<meta name="description" content="<%= seo ? seo.desc : 'Best Coaching Institute in Deoli' %>">
<meta name="keywords" content="<%= seo ? seo.keywords : 'education, coaching' %>">
    <link rel="stylesheet" href="style.css?v=1.1">
     <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>

<script src="header.js"></script>
    <my-header></my-header>

    <section class="breadcrumb-area">

        <div class="shape-globe">
            <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="#FFA500" stroke-width="1.5"
                stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M2 12h20"></path>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z">
                </path>
            </svg>
        </div>

        <div class="shape-loop">
            <svg width="40" height="40" viewBox="0 0 100 100" fill="none" stroke="#C4C6E5" stroke-width="12"
                stroke-linecap="round">
                <path d="M30,20 Q60,5 80,40 T50,90 T20,60" />
            </svg>
        </div>

        <div class="shape-scribbles">
            <svg width="80" height="100" viewBox="0 0 100 100" fill="none" stroke="#FFC07F" stroke-width="3">
                <path d="M80,10 Q90,20 85,30 T90,50" />
                <path d="M60,15 Q70,5 75,25 T80,40" />
                <path d="M90,5 Q100,15 95,25 T100,45" />
            </svg>
        </div>

        <div class="container">
            <div class="banner-content align-left">
                <span class="sub-heading">Agrim Classes</span>
                <h1 class="page-title">Target</h1>
                <ul class="breadcrumb-list">
                    <li><a href="index.html">Home</a></li>
                    <li class="separator"><i class="fas fa-chevron-right"></i></li>
                    <li>Batches</li>
                    <li class="separator"><i class="fas fa-chevron-right"></i></li>
                    <li class="active">Target</li>
                </ul>
            </div>
        </div>
    </section>

    <section class="pre-found-hero">
    <div class="hero-shapes">
        <div class="shape s-1"></div>
        <div class="shape s-2"></div>
    </div>
    <div class="container">
        <div class="hero-content text-center">
            <span class="badge-pill-glow">For Droppers & Repeaters (JEE / NEET)</span>
            
            <h1 class="hero-title">Reignite Your Dream Career <br><span class="text-gradient">Agrim Target</span></h1>
            
            <p class="hero-desc">
                We understand that life can sometimes get in the way of your goals. Whether you took a break 
                or need a second chance, <strong>Agrim Target</strong> is designed to get you back on track. 
                Our dropout programs combine proven teaching methods with <strong>AI & Machine Learning</strong> 
                to ensure you achieve your dream career in medicine or engineering.
            </p>
            
            <div class="hero-btns">
                <a href="#comeback-plan" class="btn-primary">Start Your Comeback</a>
                <a href="contact.html" class="btn-secondary">Talk to a Mentor</a>
            </div>
        </div>
    </div>
</section>

<section class="why-early-section" id="comeback-plan">
    <div class="" style="margin-left: 70px; margin-right: 70px;">
        <div class="section-header text-center mb-5">
            <span class="sub-heading">Technology Meets Resilience</span>
            <h2>Empowering Your Comeback</h2>
            <p class="section-desc mt-2">Cutting-edge technologies like AI & ML to personalize your experience.</p>
        </div>
        
        <div class="early-grid">
            <div class="early-card">
                <div class="icon-box ib-blue"><i class="fas fa-route"></i></div>
                <h4>Personalized Paths</h4>
                <p>We leverage AI to analyze your academic background, creating a customized study plan that fills knowledge gaps and targets your specific needs.</p>
            </div>
            
            <div class="early-card">
                <div class="icon-box ib-orange"><i class="fas fa-gamepad"></i></div>
                <h4>Gamified Learning</h4>
                <p>Interactive modules powered by AI make learning fun. Delve into complex concepts through simulations, animations, and gamified exercises.</p>
            </div>
            
            <div class="early-card">
                <div class="icon-box ib-purple"><i class="fas fa-flask"></i></div>
                <h4>Virtual Lab Access</h4>
                <p>Conduct experiments in immersive virtual labs. AI-powered simulations provide a safe environment for hands-on learning anywhere.</p>
            </div>
            
            <div class="early-card">
                <div class="icon-box ib-green"><i class="fas fa-tachometer-alt"></i></div>
                <h4>Real-Time Tracking</h4>
                <p>Our AI-driven system provides constant insights into your progress, allowing educators to adjust your study plan for optimal results.</p>
            </div>
        </div>
    </div>
</section>

<section class="journey-section">
    <div class="">
        <div class="text-center mb-5">
            <h2 class="main-heading">Your Path to Victory</h2>
            <p class="section-desc">A focused, accelerated approach to clear JEE/NEET.</p>
        </div>

        <div class="journey-wrapper">
            
            <div class="journey-item">
                <div class="j-content">
                    <span class="step-badge">Phase 1</span>
                    <h3>Diagnostic & Reboot</h3>
                    <p>
                        <strong>Focus: Identify & Repair</strong><br>
                        We don't just start teaching; we analyze. Using AI, we identify your 
                        strengths and weaknesses from previous attempts. We create a 
                        tailored roadmap to fill "knowledge gaps" immediately.
                    </p>
                    <div class="tags">
                        <span>Gap Analysis</span>
                        <span>Custom Plan</span>
                    </div>
                </div>
                <div class="j-visual">
                    <div class="visual-circle circle-1"><i class="fas fa-search-location"></i></div>
                </div>
            </div>

            <div class="journey-item item-reverse">
                <div class="j-content">
                    <span class="step-badge">Phase 2</span>
                    <h3>Immersive Mastery</h3>
                    <p>
                        <strong>Focus: Depth & Visualization</strong><br>
                        Dive deep into subjects using <strong>Virtual Labs</strong> and interactive animations. 
                        This ensures you don't just memorize, but visualize and understand complex 
                        scientific phenomena.
                    </p>
                    <div class="tags">
                        <span>Virtual Labs</span>
                        <span>Deep Dive</span>
                    </div>
                </div>
                <div class="j-visual">
                    <div class="visual-circle circle-2"><i class="fas fa-brain"></i></div>
                </div>
            </div>

            <div class="journey-item">
                <div class="j-content">
                    <span class="step-badge">Phase 3</span>
                    <h3>Adaptive Testing</h3>
                    <p>
                        <strong>Focus: Exam Temperament</strong><br>
                        Take advantage of <strong>Adaptive Assessments</strong> that dynamically adjust difficulty 
                        based on your performance. This keeps you constantly challenged and 
                        motivated until you are exam-ready.
                    </p>
                    <div class="tags">
                        <span>Rank Boosting</span>
                        <span>Adaptive AI</span>
                    </div>
                </div>
                <div class="j-visual">
                    <div class="visual-circle circle-3"><i class="fas fa-flag-checkered"></i></div>
                </div>
            </div>

        </div>
    </div>
</section>

<section class="boosters-section">
    <div class="" style="margin-left: 70px; margin-right: 70px;">
        <div class="text-center mb-5">
            <h2 class="main-heading">Why Choose Agrim Target?</h2>
        </div>

        <div class="boosters-grid">
            <div class="booster-card card-red">
                <div class="icon-wrapper"><i class="fas fa-user-md"></i></div>
                <h4>Dedicated<br>Mentorship</h4>
            </div>
            <div class="booster-card card-green">
                <div class="icon-wrapper"><i class="fas fa-history"></i></div>
                <h4>Proven<br>Methods</h4>
            </div>
            <div class="booster-card card-dark-blue">
                <div class="icon-wrapper"><i class="fas fa-robot"></i></div>
                <h4>AI-Powered<br>Insights</h4>
            </div>
            <div class="booster-card card-light-blue">
                <div class="icon-wrapper"><i class="fas fa-book"></i></div>
                <h4>Comprehensive<br>Material</h4>
            </div>
            <div class="booster-card card-grey">
                <div class="icon-wrapper"><i class="fas fa-check-double"></i></div>
                <h4>Regular<br>Testing</h4>
            </div>
        </div>
    </div>
</section>

<section class="creative-cta-box">
    <div class="container">
        <div class="cta-inner">
            <div class="cta-text">
                <h2>Don't Let Past Setbacks Define You.</h2>
                <p>Agrim Target is here to help you turn your dreams into reality.</p>
            </div>
            <div class="cta-btn">
                <a href="contact.html" class="btn-white">Apply for Target Batch</a>
            </div>
        </div>
    </div>
</section>

<my-footer></my-footer>


<script src="footer.js"></script>
    </body>