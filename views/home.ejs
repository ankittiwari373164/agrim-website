// =========================================
    // DYNAMIC EFFECTS SCRIPT (Paste at bottom of script tag)
    // =========================================

    document.addEventListener("DOMContentLoaded", function() {
        
        // 1. Select elements to animate
        // We select headers, paragraphs, buttons, and cards
        const elementsToAnimate = document.querySelectorAll(
            'h1, .sub-header, .hero-section p, .cta-wrapper, ' + 
            '.about-image-wrapper, .about-content, ' +
            '.course-card, .feature-item, .video-gallery-wrapper, .blog-card'
        );

        // 2. Add the base CSS class to them
        elementsToAnimate.forEach((el) => {
            el.classList.add('reveal-element');
        });

        // 3. Add delays to grid items for "Staggered" effect
        const grids = document.querySelectorAll('.course-grid, .blog-grid, .features-grid');
        grids.forEach(grid => {
            const children = grid.children;
            for (let i = 0; i < children.length; i++) {
                // Add staggered delay classes (100ms, 200ms, 300ms...)
                let delay = (i % 3) * 100; // Reset every 3 items
                if(delay > 0) {
                    children[i].style.transitionDelay = `${delay}ms`;
                }
            }
        });

        // 4. Create the Intersection Observer
        const observerOptions = {
            root: null,
            rootMargin: '0px',
            threshold: 0.15 // Trigger when 15% of element is visible
        };

        const observer = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                    observer.unobserve(entry.target); // Only animate once
                }
            });
        }, observerOptions);

        // 5. Start Observing
        elementsToAnimate.forEach(el => {
            observer.observe(el);
        });
    });
</script>

