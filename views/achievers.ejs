<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= seo ? seo.title : 'Agrim Classes' %></title>
<meta name="description" content="<%= seo ? seo.desc : 'Best Coaching Institute in Deoli' %>">
<meta name="keywords" content="<%= seo ? seo.keywords : 'education, coaching' %>">
    <link rel="stylesheet" href="style.css?v=1.1">
     <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>

<script src="header.js"></script>
    <my-header></my-header>

    <section class="breadcrumb-area">

        <div class="shape-globe">
            <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="#FFA500" stroke-width="1.5"
                stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M2 12h20"></path>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z">
                </path>
            </svg>
        </div>

        <div class="shape-loop">
            <svg width="40" height="40" viewBox="0 0 100 100" fill="none" stroke="#C4C6E5" stroke-width="12"
                stroke-linecap="round">
                <path d="M30,20 Q60,5 80,40 T50,90 T20,60" />
            </svg>
        </div>

        <div class="shape-scribbles">
            <svg width="80" height="100" viewBox="0 0 100 100" fill="none" stroke="#FFC07F" stroke-width="3">
                <path d="M80,10 Q90,20 85,30 T90,50" />
                <path d="M60,15 Q70,5 75,25 T80,40" />
                <path d="M90,5 Q100,15 95,25 T100,45" />
            </svg>
        </div>

        <div class="container">
            <div class="banner-content align-left">
                <span class="sub-heading">Agrim Classes</span>
                <h1 class="page-title">Achievers</h1>
                <ul class="breadcrumb-list">
                    <li><a href="index.html">Home</a></li>
                    <li class="separator"><i class="fas fa-chevron-right"></i></li>
                    <li>Batches</li>
                    <li class="separator"><i class="fas fa-chevron-right"></i></li>
                    <li class="active">Achievers</li>
                </ul>
            </div>
        </div>
    </section>

    <section class="pre-found-hero">
    <div class="hero-shapes">
        <div class="shape s-1"></div>
        <div class="shape s-2"></div>
    </div>
    <div class="container">
        <div class="hero-content text-center">
            <span class="badge-pill-glow">Class 11th & 12th (Science & Commerce)</span>
            
            <h1 class="hero-title">From Learning to Leading <br><span class="text-gradient">Achieve Your Ambitions</span></h1>
            
            <p class="hero-desc">
                The <strong>Agrim Achievers</strong> batches are specially curated for students who are driven, 
                dedicated, and determined to excel. We go beyond the classroom, preparing you not just for 
                Board Exams but for prestigious competitive exams like <strong>JEE Main, NEET, and AIIMS</strong>.
            </p>
            
            <div class="hero-btns">
                <a href="#tech-advantage" class="btn-primary">View AI Advantage</a>
                <a href="contact.html" class="btn-secondary">Join Achievers Batch</a>
            </div>
        </div>
    </div>
</section>

<section class="why-early-section" id="tech-advantage">
    <div class="" style="margin-left: 70px; margin-right: 70px;">
        <div class="section-header text-center mb-5">
            <span class="sub-heading">Next-Gen Learning</span>
            <h2>AI-Powered Preparation</h2>
            <p class="section-desc mt-2">We integrate Artificial Intelligence (AI) & Machine Learning (ML) to revolutionize your prep.</p>
        </div>
        
        <div class="early-grid">
            <div class="early-card">
                <div class="icon-box ib-blue"><i class="fas fa-route"></i></div>
                <h4>Tailored Learning Paths</h4>
                <p>AI algorithms analyze your performance data to craft bespoke study paths catering to your unique strengths and weaknesses.</p>
            </div>
            
            <div class="early-card">
                <div class="icon-box ib-purple"><i class="fas fa-vr-cardboard"></i></div>
                <h4>Virtual Laboratories</h4>
                <p>Conduct experiments and explore scientific concepts hands-on in immersive virtual environments, regardless of physical resources.</p>
            </div>
            
            <div class="early-card">
                <div class="icon-box ib-orange"><i class="fas fa-chart-line"></i></div>
                <h4>Dynamic Monitoring</h4>
                <p>Real-time insights into your advancement, empowering educators to adapt teaching strategies for optimal outcomes.</p>
            </div>
            
            <div class="early-card">
                <div class="icon-box ib-green"><i class="fas fa-cogs"></i></div>
                <h4>Adaptive Testing</h4>
                <p>Assessment tools that dynamically adjust question difficulty based on your performance, ensuring continuous growth.</p>
            </div>
        </div>
    </div>
</section>

<section class="journey-section">
    <div class="">
        <div class="text-center mb-5">
            <h2 class="main-heading">The Path to Rank #1</h2>
            <p class="section-desc">A structured approach for Science (PCM/PCB) and Commerce students.</p>
        </div>

        <div class="journey-wrapper">
            
            <div class="journey-item">
                <div class="j-content">
                    <span class="step-badge">Phase 1</span>
                    <h3>Foundation Building (Class 11)</h3>
                    <p>
                        <strong>Focus: Concepts & Logic</strong><br>
                        We utilize AI algorithms to identify your learning baseline. The focus is on 
                        deep conceptual understanding of Physics, Chemistry, Maths/Biology, 
                        setting the stage for advanced application.
                    </p>
                    <div class="tags">
                        <span>Concept Clarity</span>
                        <span>AI Analysis</span>
                    </div>
                </div>
                <div class="j-visual">
                    <div class="visual-circle circle-1"><i class="fas fa-atom"></i></div>
                </div>
            </div>

            <div class="journey-item item-reverse">
                <div class="j-content">
                    <span class="step-badge">Phase 2</span>
                    <h3>Board & Exam Mastery (Class 12)</h3>
                    <p>
                        <strong>Focus: Balance & Precision</strong><br>
                        We integrate school syllabus with competitive prep. Students engage with 
                        interactive modules and virtual labs to visualize complex topics, ensuring 
                        high marks in Boards and Entrance exams.
                    </p>
                    <div class="tags">
                        <span>Board Topper</span>
                        <span>Virtual Labs</span>
                    </div>
                </div>
                <div class="j-visual">
                    <div class="visual-circle circle-2"><i class="fas fa-microscope"></i></div>
                </div>
            </div>

            <div class="journey-item">
                <div class="j-content">
                    <span class="step-badge">Phase 3</span>
                    <h3>The Final Sprint</h3>
                    <p>
                        <strong>Focus: Speed & Rank Boosting</strong><br>
                        Adaptive evaluation systems challenge you with tougher questions as you improve. 
                        Comprehensive revision, mock series, and doubt clearing ensures you are exam-ready.
                    </p>
                    <div class="tags">
                        <span>Rank Booster</span>
                        <span>Adaptive Tests</span>
                    </div>
                </div>
                <div class="j-visual">
                    <div class="visual-circle circle-3"><i class="fas fa-trophy"></i></div>
                </div>
            </div>

        </div>
    </div>
</section>

<section class="boosters-section">
    <div class="" style="margin-left: 70px; margin-right: 70px;">
        <div class="text-center mb-5">
            <h2 class="main-heading">Comprehensive Practice</h2>
            
        </div>

        <div class="boosters-grid">
            <div class="booster-card card-red">
                <div class="icon-wrapper"><i class="fas fa-file-contract"></i></div>
                <h4>Daily Practice<br>Sheets</h4>
            </div>
            <div class="booster-card card-green">
                <div class="icon-wrapper"><i class="fas fa-clock"></i></div>
                <h4>Weekly<br>Mock Tests</h4>
            </div>
            <div class="booster-card card-dark-blue">
                <div class="icon-wrapper"><i class="fas fa-user-graduate"></i></div>
                <h4>Expert<br>Faculty</h4>
            </div>
            <div class="booster-card card-light-blue">
                <div class="icon-wrapper"><i class="fas fa-laptop-code"></i></div>
                <h4>Online<br>Resources</h4>
            </div>
            <div class="booster-card card-grey">
                <div class="icon-wrapper"><i class="fas fa-chart-pie"></i></div>
                <h4>Monthly<br>Assessments</h4>
            </div>
        </div>
    </div>
</section>

<section class="creative-cta-box">
    <div class="" style="margin-left: 70px; margin-right: 70px;">
        <div class="cta-inner">
            <div class="cta-text">
                <h2>Ready to Lead the Future?</h2>
                <p>Join Agrim Achievers and experience the power of AI-driven coaching.</p>
            </div>
            <div class="cta-btn">
                <a href="contact.html" class="btn-white">Apply for Achievers</a>
            </div>
        </div>
    </div>
</section>

<my-footer></my-footer>


<script src="footer.js"></script>
    </body>