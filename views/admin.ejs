<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Agrim Classes Admin</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root { --bg: #1a1a2e; --card: #16213e; --text: #fff; --accent: #FF725E; --green: #2ecc71; }
        body { font-family: 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); padding: 30px; }
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
        .date-select { padding: 10px; background: #0f3460; color: white; border: 1px solid #333; border-radius: 6px; cursor: pointer; }
        .grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 20px; margin-bottom: 25px; }
        .col-3 { grid-column: span 3; } .col-4 { grid-column: span 4; } .col-6 { grid-column: span 6; } .col-8 { grid-column: span 8; } .col-9 { grid-column: span 9; } .col-12 { grid-column: span 12; }
        .card { background: var(--card); padding: 25px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.3); }
        .card h2 { margin: 0 0 10px 0; color: #a0a0a0; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; }
        .big-num { font-size: 2.2rem; font-weight: bold; color: var(--text); }
        .sub-text { font-size: 0.9rem; color: var(--green); margin-top: 5px; }
        table { width: 100%; border-collapse: collapse; margin-top: 15px; font-size: 0.9rem; }
        th, td { text-align: left; padding: 12px; border-bottom: 1px solid #333; }
        th { color: #888; font-weight: normal; background: #0f2444; }
        tr:hover { background: #1f2e50; }
        .tag { padding: 3px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: bold; }
        .tag-mobile { background: #e67e22; color: white; }
        .tag-desktop { background: #3498db; color: white; }
        input, textarea { width: 100%; padding: 12px; background: #0f3460; border: 1px solid #222; color: white; margin-bottom: 15px; border-radius: 6px; box-sizing: border-box;}
        button { background: var(--accent); color: white; border: none; padding: 12px 25px; cursor: pointer; border-radius: 6px; font-weight: bold; transition: 0.3s; }
        button:hover { background: #e64a19; }
    </style>
</head>
<body>
<div class="header">
    <h1>📚 Agrim Classes Admin</h1>
    <div style="display:flex; gap:15px; align-items:center;">
        <select class="date-select" onchange="window.location.href='/admin?days='+this.value">
            <option value="7" <%= selectedDays == 7 ? 'selected' : '' %>>Last 7 Days</option>
            <option value="14" <%= selectedDays == 14 ? 'selected' : '' %>>Last 14 Days</option>
            <option value="30" <%= selectedDays == 30 ? 'selected' : '' %>>Last 30 Days</option>
        </select>
        <a href="/logout" style="color: var(--accent); text-decoration: none; font-weight: bold;">Logout</a>
    </div>
</div>

<div class="grid">
    <div class="card col-3">
        <h2>Total Views</h2>
        <div class="big-num"><%= totalViews %></div>
        <div class="sub-text">▲ Visits in <%= selectedDays %> days</div>
    </div>
    <div class="card col-3">
        <h2>Total Leads</h2>
        <div class="big-num"><%= totalLeads %></div>
        <div class="sub-text">▲ Form submissions</div>
    </div>
    <div class="card col-3">
        <h2>Bounce Rate</h2>
        <div class="big-num"><%= bounceRate %>%</div>
        <div class="sub-text" style="color: #f1c40f;">Avg. <%= bounceRate %>%</div>
    </div>
    <div class="card col-3">
        <h2>Avg. Time</h2>
        <div class="big-num"><%= avgTime %></div>
        <div class="sub-text">Per Session</div>
    </div>
</div>

<div class="grid">
    <div class="card col-9">
        <h2>Traffic Trends</h2>
        <div style="height: 300px;"><canvas id="chart"></canvas></div>
    </div>
    <div class="card col-3">
        <h2>Device Type</h2>
        <div style="height: 250px;"><canvas id="pie"></canvas></div>
    </div>
</div>

<div class="grid">
    <div class="card col-4">
        <h2>🔥 Top Visited Pages</h2>
        <table>
            <tbody>
                <% popularPages.forEach(function(page) { %>
                    <tr>
                        <td style="text-transform: capitalize;"><strong>/<%= page._id %></strong></td>
                        <td style="color: #2ecc71; text-align: right;"><%= page.count %> Views</td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>

    <div class="card col-8">
        <div style="display:flex; justify-content:space-between; margin-bottom: 20px;">
            <div>
                <h2>🚀 Multi-Page SEO Manager</h2>
                <span style="font-size: 0.8rem; color: #888;">Select a page to view or edit its metadata.</span>
            </div>
            <a href="/admin/force-update" style="background: var(--accent); color: white; padding: 8px 15px; text-decoration: none; border-radius: 4px; font-size: 0.8rem; font-weight: bold;">⚡ Force News Update</a>
        </div>

        <div style="max-height: 400px; overflow-y: auto; padding-right: 10px;">
            <% allSeo.forEach(function(seoItem) { %>
                <div style="background: #0f2444; padding: 15px; border-radius: 8px; margin-bottom: 15px; border-left: 4px solid var(--green);">
                    <form action="/admin/seo" method="POST">
                        <div style="display:flex; justify-content:space-between; margin-bottom: 10px;">
                            <h3 style="margin:0; color:#fff; font-size:1.1rem; text-transform:uppercase;">Page: /<%= seoItem.pageName %></h3>
                            <button type="submit" style="padding: 6px 12px; font-size:0.8rem;">Save <%= seoItem.pageName %></button>
                        </div>
                        <input type="hidden" name="pageName" value="<%= seoItem.pageName %>">
                        <div class="grid" style="margin-bottom: 0;">
                            <div class="col-4">
                                <label style="color:#888; font-size:0.8rem;">Browser Title</label>
                                <input type="text" name="title" value="<%= seoItem.title %>" style="padding:8px; font-size:0.9rem;">
                            </div>
                            <div class="col-8">
                                <label style="color:#888; font-size:0.8rem;">Targeted Keywords (Auto-Updated)</label>
                                <input type="text" name="keywords" value="<%= seoItem.keywords %>" readonly style="opacity: 0.7; cursor: not-allowed; color: #2ecc71; padding:8px; font-size:0.9rem;">
                            </div>
                        </div>
                        <label style="color:#888; font-size:0.8rem;">Meta Description</label>
                        <textarea name="desc" rows="2" style="padding:8px; font-size:0.9rem;"><%= seoItem.desc %></textarea>
                    </form>
                </div>
            <% }); %>
        </div>
    </div>
</div>

<div class="grid">
    <div class="card col-6">
        <h2>📩 Student Inquiries</h2>
        <% if (leads.length === 0) { %>
            <p style="color:#666; font-style:italic; margin-top:20px;">No messages yet.</p>
        <% } else { %>
            <div style="overflow-x:auto;">
                <table>
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Student Info</th>
                            <th>Course/Query</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% leads.forEach(function(lead) { %>
                            <tr>
                                <td style="white-space:nowrap; font-size:0.8rem; color:#888;"><%= lead.date.toLocaleDateString() %></td>
                                <td>
                                    <strong><%= lead.name %></strong><br>
                                    <span style="font-size:0.8rem; color:#888;"><%= lead.phone %></span>
                                </td>
                                <td style="font-size:0.85rem;"><%= lead.course || lead.message %></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>

    <div class="card col-6">
        <h2>👀 Live Visitor Log</h2>
        <div style="overflow-x:auto;">
            <table>
                <thead>
                    <tr>
                        <th>Time</th>
                        <th>Page</th>
                        <th>Device</th>
                        <th>Traffic Source</th>
                    </tr>
                </thead>
                <tbody>
                    <% recentVisits.forEach(function(visit) { %>
                        <tr>
                            <td style="font-size:0.8rem; color:#888;"><%= visit.date.toLocaleTimeString() %></td>
                            <td style="font-size:0.85rem; color:#fff;">/<%= visit.page %></td>
                            <td><span class="tag <%= visit.device === 'Mobile' ? 'tag-mobile' : 'tag-desktop' %>"><%= visit.device %></span></td>
                            <td style="font-size:0.85rem; color: #2ecc71;"><%= visit.referrer.substring(0, 30) %></td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    const daily = <%- JSON.stringify(dailyStats) %>;
    const device = <%- JSON.stringify(deviceStats) %>;

    new Chart(document.getElementById('chart'), {
        type: 'line',
        data: {
            labels: daily.map(d => d._id),
            datasets: [{ 
                label: 'Visits', 
                data: daily.map(d => d.count), 
                borderColor: '#FF725E', 
                backgroundColor: 'rgba(255, 114, 94, 0.1)', 
                borderWidth: 3, fill: true, tension: 0.4
            }]
        },
        options: { maintainAspectRatio: false, scales: { y: { beginAtZero: true, grid: { color: '#333' } }, x: { grid: { display: false } } }, plugins: { legend: { display: false } } }
    });

    new Chart(document.getElementById('pie'), {
        type: 'doughnut',
        data: {
            labels: device.map(d => d._id),
            datasets: [{ data: device.map(d => d.count), backgroundColor: ['#FF725E', '#5B5F97'], borderWidth: 0 }]
        },
        options: { maintainAspectRatio: false, cutout: '70%', plugins: { legend: { position: 'bottom', labels: { color: '#fff' } } } }
    });
</script>
</body>
</html>