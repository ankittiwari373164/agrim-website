<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= seo ? seo.title : 'Agrim Classes' %></title>
<meta name="description" content="<%= seo ? seo.desc : 'Best Coaching Institute in Deoli' %>">
<meta name="keywords" content="<%= seo ? seo.keywords : 'education, coaching' %>">
    <link rel="stylesheet" href="style.css?v=1.1">
     <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>

<script src="header.js"></script>
    <my-header></my-header>

    <section class="breadcrumb-area">

        <div class="shape-globe">
            <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="#FFA500" stroke-width="1.5"
                stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M2 12h20"></path>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z">
                </path>
            </svg>
        </div>

        <div class="shape-loop">
            <svg width="40" height="40" viewBox="0 0 100 100" fill="none" stroke="#C4C6E5" stroke-width="12"
                stroke-linecap="round">
                <path d="M30,20 Q60,5 80,40 T50,90 T20,60" />
            </svg>
        </div>

        <div class="shape-scribbles">
            <svg width="80" height="100" viewBox="0 0 100 100" fill="none" stroke="#FFC07F" stroke-width="3">
                <path d="M80,10 Q90,20 85,30 T90,50" />
                <path d="M60,15 Q70,5 75,25 T80,40" />
                <path d="M90,5 Q100,15 95,25 T100,45" />
            </svg>
        </div>

        <div class="container">
            <div class="banner-content align-left">
                <span class="sub-heading">Agrim Classes</span>
                <h1 class="page-title">Elite</h1>
                <ul class="breadcrumb-list">
                    <li><a href="index.html">Home</a></li>
                    <li class="separator"><i class="fas fa-chevron-right"></i></li>
                    <li>Batches</li>
                    <li class="separator"><i class="fas fa-chevron-right"></i></li>
                    <li class="active">Elite</li>
                </ul>
            </div>
        </div>
    </section>

<section class="pre-found-hero">
    <div class="hero-shapes">
        <div class="shape s-1"></div>
        <div class="shape s-2"></div>
    </div>
    <div class="container">
        <div class="hero-content text-center">
            <span class="badge-pill-glow">Class 11 & 12 (Science & Commerce)</span>
            
            <h1 class="hero-title">Where Precision Meets <br><span class="text-gradient">Performance</span></h1>
            
            <p class="hero-desc">
                Introducing the <strong>Agrim Elite Batch</strong> — where innovation intersects with academic excellence. 
                Crafted with meticulous attention to detail and driven by a relentless pursuit of perfection, 
                this program stands as a benchmark in advanced learning and competitive exam preparation.
            </p>
            
            <div class="hero-btns">
                <a href="#elite-values" class="btn-primary">Discover Elite</a>
                <a href="contact.html" class="btn-secondary">Apply for Admission</a>
            </div>
        </div>
    </div>
</section>

<section class="why-early-section" id="elite-values">
    <div class="" style="margin-left: 70px; margin-right: 70px;">
        <div class="section-header text-center mb-5">
            <span class="sub-heading">Core Values</span>
            <h2>Redefining Excellence</h2>
            <p class="section-desc mt-2">Designed to elevate students' academic journeys to new heights.</p>
        </div>
        
        <div class="early-grid">
            <div class="early-card">
                <div class="icon-box ib-blue"><i class="fas fa-user-clock"></i></div>
                <h4>Discipline</h4>
                <p>A structured environment that fosters consistency and focus, essential for mastering complex curriculums.</p>
            </div>
            
            <div class="early-card">
                <div class="icon-box ib-purple"><i class="fas fa-lightbulb"></i></div>
                <h4>Clarity</h4>
                <p>Mastering complex concepts in Physics, Chemistry, Biology, or Accountancy with absolute conceptual clarity.</p>
            </div>
            
            <div class="early-card">
                <div class="icon-box ib-orange"><i class="fas fa-trophy"></i></div>
                <h4>Achievement</h4>
                <p>Driven by results. We ensure every student is prepared not just to perform, but to excel in competitive exams.</p>
            </div>
            
            <div class="early-card">
                <div class="icon-box ib-green"><i class="fas fa-chess-knight"></i></div>
                <h4>Strategic Mentoring</h4>
                <p>Personalized attention and strategy sessions to navigate the pressure of Board Exams and Entrance Tests.</p>
            </div>
        </div>
    </div>
</section>

<section class="journey-section">
    <div class="">
        <div class="text-center mb-5">
            <h2 class="main-heading">The Path to Perfection</h2>
            <p class="section-desc">A benchmark in advanced learning for JEE, NEET, and Commerce.</p>
        </div>

        <div class="journey-wrapper">
            
            <div class="journey-item">
                <div class="j-content">
                    <span class="step-badge">Phase 1</span>
                    <h3>Academic Brilliance</h3>
                    <p>
                        <strong>Focus: Strong Foundation</strong><br>
                        Whether studying PCM/PCB or Commerce, we build a robust foundation. 
                        Our curriculum is aligned to CBSE Class 11 & 12 while integrating 
                        advanced concepts for <strong>JEE Mains, NEET</strong>, and other entrance exams.
                    </p>
                    <div class="tags">
                        <span>CBSE Aligned</span>
                        <span>Competitive Base</span>
                    </div>
                </div>
                <div class="j-visual">
                    <div class="visual-circle circle-1"><i class="fas fa-university"></i></div>
                </div>
            </div>

            <div class="journey-item item-reverse">
                <div class="j-content">
                    <span class="step-badge">Phase 2</span>
                    <h3>Advanced Learning</h3>
                    <p>
                        <strong>Focus: Tradition meets Technology</strong><br>
                        We use advanced teaching methods where tradition meets technology. 
                        Students tackle every academic challenge with confidence through 
                        regular assessments and focused doubt-solving sessions.
                    </p>
                    <div class="tags">
                        <span>Tech Integration</span>
                        <span>Regular Assessments</span>
                    </div>
                </div>
                <div class="j-visual">
                    <div class="visual-circle circle-2"><i class="fas fa-laptop-code"></i></div>
                </div>
            </div>

            <div class="journey-item">
                <div class="j-content">
                    <span class="step-badge">Phase 3</span>
                    <h3>Future Leaders</h3>
                    <p>
                        <strong>Focus: Career Empowerment</strong><br>
                        Agrim Elite is more than a classroom; it's a movement. We nurture potential 
                        and ignite curiosity to build a strong foundation for future careers, 
                        redefining education through excellence.
                    </p>
                    <div class="tags">
                        <span>Career Ready</span>
                        <span>Top Rankers</span>
                    </div>
                </div>
                <div class="j-visual">
                    <div class="visual-circle circle-3"><i class="fas fa-user-graduate"></i></div>
                </div>
            </div>

        </div>
    </div>
</section>

<section class="boosters-section">
    <div class="" style="margin-left: 70px; margin-right: 70px;">
        <div class="text-center mb-5">
            <h2 class="main-heading">The Elite Advantage</h2>
        </div>

        <div class="boosters-grid">
            <div class="booster-card card-red">
                <div class="icon-wrapper"><i class="fas fa-chalkboard-teacher"></i></div>
                <h4>Advanced<br>Teaching</h4>
            </div>
            <div class="booster-card card-green">
                <div class="icon-wrapper"><i class="fas fa-bullseye"></i></div>
                <h4>Precision<br>Learning</h4>
            </div>
            <div class="booster-card card-dark-blue">
                <div class="icon-wrapper"><i class="fas fa-hand-holding-medical"></i></div>
                <h4>Personalized<br>Attention</h4>
            </div>
            <div class="booster-card card-light-blue">
                <div class="icon-wrapper"><i class="fas fa-question"></i></div>
                <h4>Focused<br>Doubt Solving</h4>
            </div>
            <div class="booster-card card-grey">
                <div class="icon-wrapper"><i class="fas fa-chart-bar"></i></div>
                <h4>Performance<br>Tracking</h4>
            </div>
        </div>
    </div>
</section>

<section class="creative-cta-box">
    <div class="" style="margin-left: 70px; margin-right: 70px;">
        <div class="cta-inner">
            <div class="cta-text">
                <h2>Step Into the Future of Learning</h2>
                <p>Join the Agrim Elite Batch and redefine your potential.</p>
            </div>
            <div class="cta-btn">
                <a href="contact.html" class="btn-white">Join Agrim Elite</a>
            </div>
        </div>
    </div>
</section>

<my-footer></my-footer>


<script src="footer.js"></script>
</body>