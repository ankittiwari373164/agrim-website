<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= seo ? seo.title : 'Agrim Classes' %></title>
<meta name="description" content="<%= seo ? seo.desc : 'Best Coaching Institute in Deoli' %>">
<meta name="keywords" content="<%= seo ? seo.keywords : 'education, coaching' %>">
    <link rel="stylesheet" href="style.css?v=1.1">
     <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <script src="header.js"></script>
    <my-header></my-header>

    <section class="breadcrumb-area">

        <div class="shape-globe">
            <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="#FFA500" stroke-width="1.5"
                stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M2 12h20"></path>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z">
                </path>
            </svg>
        </div>

        <div class="shape-loop">
            <svg width="40" height="40" viewBox="0 0 100 100" fill="none" stroke="#C4C6E5" stroke-width="12"
                stroke-linecap="round">
                <path d="M30,20 Q60,5 80,40 T50,90 T20,60" />
            </svg>
        </div>

        <div class="shape-scribbles">
            <svg width="80" height="100" viewBox="0 0 100 100" fill="none" stroke="#FFC07F" stroke-width="3">
                <path d="M80,10 Q90,20 85,30 T90,50" />
                <path d="M60,15 Q70,5 75,25 T80,40" />
                <path d="M90,5 Q100,15 95,25 T100,45" />
            </svg>
        </div>

        <div class="container">
            <div class="banner-content align-left">
                <span class="sub-heading">Agrim Classes</span>
                <h1 class="page-title">Foundation</h1>
                <ul class="breadcrumb-list">
                    <li><a href="/">Home</a></li>
                    <li class="separator"><i class="fas fa-chevron-right"></i></li>
                    <li>Batches</li>
                    <li class="separator"><i class="fas fa-chevron-right"></i></li>
                    <li class="active">Foundation</li>
                </ul>
            </div>
        </div>
    </section>

<section class="pre-found-hero">
    <div class="hero-shapes">
        <div class="shape s-1"></div>
        <div class="shape s-2"></div>
    </div>
    <div class="container">
        <div class="hero-content text-center">
            <span class="badge-pill-glow">Class 9th & 10th</span>
            
            <h1 class="hero-title">Your Journey Begins with a <br><span class="text-gradient">Solid Foundation</span></h1>
            
            <p class="hero-desc">
                At Agrim Classes, we offer a specialized learning experience designed to provide students 
                in Classes 9 and 10 with the right tools for success. Our programs are meticulously crafted 
                to help students master school subjects while building the base for JEE Main, NEET, and AIIMS.
            </p>
            
            <div class="hero-btns">
                <a href="#learning-steps" class="btn-primary">Explore the Path</a>
                <a href="/contact" class="btn-secondary">Get Syllabus</a>
            </div>
        </div>
    </div>
</section>

<section class="why-early-section">
    <div class="" style="margin-left: 70px; margin-right: 70px;">
        <div class="section-header text-center mb-5">
            <span class="sub-heading">Program Details</span>
            <h2>Comprehensive Learning Approach</h2>
        </div>
        
        <div class="early-grid">
            <div class="early-card">
                <div class="icon-box ib-blue"><i class="fas fa-book-reader"></i></div>
                <h4>Integrated Curriculum</h4>
                <p>Covers the entire syllabus for Board Exams while integrating advanced topics necessary for JEE, NEET, and KVPY.</p>
            </div>
            
            <div class="early-card">
                <div class="icon-box ib-orange"><i class="far fa-calendar-alt"></i></div>
                <h4>Flexible Schedule</h4>
                <p>Weekday and weekend classes designed to balance theory, practice, and revision without overwhelming students.</p>
            </div>
            
            <div class="early-card">
                <div class="icon-box ib-purple"><i class="fas fa-file-alt"></i></div>
                <h4>Expert Content</h4>
                <p>Detailed study notes for Math & Science, specifically created for both class-level understanding and competitive prep.</p>
            </div>
            
            <div class="early-card">
                <div class="icon-box ib-green"><i class="fas fa-tasks"></i></div>
                <h4>Continuous Assessment</h4>
                <p>Daily practice sheets, weekly mock tests, and periodic assessments to track progress and improve speed.</p>
            </div>
        </div>
    </div>
</section>

<section class="journey-section" id="learning-steps">
    <div class="">
        <div class="text-center mb-5">
            <h2 class="main-heading">Advanced Learning & Specialization</h2>
            <p class="section-desc">A structured 3-step approach to mastering concepts.</p>
        </div>

        <div class="journey-wrapper">
            
            <div class="journey-item">
                <div class="j-content">
                    <span class="step-badge">Step 1</span>
                    <h3>Concept Mastery</h3>
                    <p>
                        Begin with a solid understanding of <strong>Mathematics and Science</strong> fundamentals. 
                        We focus on mastering key subjects like algebra, physics, chemistry, and biology to build 
                        a strong academic foundation.
                    </p>
                    <div class="tags">
                        <span>Solid Grasp</span>
                        <span>Essential Concepts</span>
                    </div>
                </div>
                <div class="j-visual">
                    <div class="visual-circle circle-1"><i class="fas fa-cubes"></i></div>
                </div>
            </div>

            <div class="journey-item item-reverse">
                <div class="j-content">
                    <span class="step-badge">Step 2</span>
                    <h3>Interactive Application</h3>
                    <p>
                        Participate in practical exercises, group discussions, and real-world case studies. 
                        We apply core knowledge to enhance your <strong>problem-solving</strong> and 
                        analytical skills, connecting theory to reality.
                    </p>
                    <div class="tags">
                        <span>Hands-on</span>
                        <span>Case Studies</span>
                    </div>
                </div>
                <div class="j-visual">
                    <div class="visual-circle circle-2"><i class="fas fa-flask"></i></div>
                </div>
            </div>

            <div class="journey-item">
                <div class="j-content">
                    <span class="step-badge">Step 3</span>
                    <h3>Advanced Specialization</h3>
                    <p>
                        Once the foundation is secure, dive into specialized topics. This stage prepares 
                        you for advanced coursework and future career opportunities in engineering 
                        or medical fields.
                    </p>
                    <div class="tags">
                        <span>Career Ready</span>
                        <span>Advanced Topics</span>
                    </div>
                </div>
                <div class="j-visual">
                    <div class="visual-circle circle-3"><i class="fas fa-microscope"></i></div>
                </div>
            </div>

        </div>
    </div>
</section>

<section class="boosters-section">
    <div class="" style="margin-left: 70px; margin-right: 70px;">
        <div class="text-center mb-5">
            <h2 class="main-heading">Practice & Assessment Tools</h2>
        </div>

        <div class="boosters-grid">
            <div class="booster-card card-red">
                <div class="icon-wrapper"><i class="fas fa-calendar-day"></i></div>
                <h4>Daily<br>Practice Sheets</h4>
            </div>
            <div class="booster-card card-green">
                <div class="icon-wrapper"><i class="fas fa-stopwatch"></i></div>
                <h4>Weekly<br>Mock Tests</h4>
            </div>
            <div class="booster-card card-dark-blue">
                <div class="icon-wrapper"><i class="fas fa-user-check"></i></div>
                <h4>Personalized<br>Feedback</h4>
            </div>
            <div class="booster-card card-light-blue">
                <div class="icon-wrapper"><i class="fas fa-question-circle"></i></div>
                <h4>Doubt<br>Clearing</h4>
            </div>
            <div class="booster-card card-grey">
                <div class="icon-wrapper"><i class="fas fa-laptop-code"></i></div>
                <h4>Online<br>Resources</h4>
            </div>
        </div>
    </div>
</section>

<section class="creative-cta-box">
    <div class="" style="margin-left: 70px; margin-right: 70px;">
        <div class="cta-inner">
            <div class="cta-text">
                <h2>Build Your Future With Agrim</h2>
                <p>Admissions open for Class 9 & 10 Foundation Batch.</p>
            </div>
            <div class="cta-btn">
                <a href="/contact" class="btn-white">Apply Now</a>
            </div>
        </div>
    </div>
</section>

<my-footer></my-footer>
<script src="footer.js"></script>
</body>